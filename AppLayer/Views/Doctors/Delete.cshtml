@model BLL.DTOs.DoctorDTO

@{
    ViewData["Title"] = "Delete Doctor";
}

<div class="container mt-5">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Doctor</h4>
        </div>

        <div class="card-body">
            <div class="alert alert-warning">
                Are you sure you want to delete this doctor?
            </div>

            <dl class="row">
                <dt class="col-sm-3">Doctor ID</dt>
                <dd class="col-sm-9">@Model.DoctorId</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">Dr. @Model.FirstName @Model.LastName</dd>

                <dt class="col-sm-3">Speciality</dt>
                <dd class="col-sm-9">@Model.Speciality</dd>

                <dt class="col-sm-3">Consultation Fee</dt>
                <dd class="col-sm-9">@Model.ConsultationFee.ToString("0.00")</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Availability</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Unavailable</span>
                    }
                </dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.DoctorId" method="post">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>