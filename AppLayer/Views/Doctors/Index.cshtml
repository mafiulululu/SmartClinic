@model IEnumerable<DAL.EF.Table.Doctor>

@{
    ViewData["Title"] = "Doctors";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Doctors</h2>
            <p class="text-muted mb-0">Search doctors by speciality, fee, and availability</p>
        </div>

        @if (User.IsInRole("Admin"))
        {
            <a asp-action="Create" class="btn btn-primary">
                + Add Doctor
            </a>
        }
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm mb-4">
        <div class="card-header bg-light">
            <strong>Search & Filter Doctors</strong>
        </div>

        <div class="card-body">
            <form asp-action="Index" method="get" class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Speciality</label>
                    <input type="text"
                           name="speciality"
                           value="@ViewBag.Speciality"
                           class="form-control"
                           placeholder="Example: Cardiology" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Minimum Fee</label>
                    <input type="number"
                           name="minFee"
                           value="@ViewBag.MinFee"
                           class="form-control"
                           step="0.01"
                           placeholder="Example: 500" />
                </div>

                <div class="col-md-3">
                    <label class="form-label">Maximum Fee</label>
                    <input type="number"
                           name="maxFee"
                           value="@ViewBag.MaxFee"
                           class="form-control"
                           step="0.01"
                           placeholder="Example: 1500" />
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               name="availableOnly"
                               value="true"
                        @(ViewBag.AvailableOnly == true ? "checked" : "") />

                        <label class="form-check-label">
                            Available only
                        </label>
                    </div>
                </div>

                <div class="col-md-12">
                    <button type="submit" class="btn btn-success">
                        Search
                    </button>

                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        Clear
                    </a>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <strong>Doctor List</strong>
            <span class="badge bg-info text-dark">
                Total Found: @Model.Count()
            </span>
        </div>

        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Doctor ID</th>
                            <th>Name</th>
                            <th>Speciality</th>
                            <th>Consultation Fee</th>
                            <th>Email</th>
                            <th>Availability</th>

                            @if (User.IsInRole("Admin"))
                            {
                                <th style="width: 180px;">Actions</th>
                            }
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var doctor in Model)
                        {
                            <tr>
                                <td>@doctor.DoctorId</td>
                                <td>Dr. @doctor.FirstName @doctor.LastName</td>
                                <td>@doctor.Speciality</td>
                                <td>@doctor.ConsultationFee.ToString("0.00")</td>
                                <td>@doctor.Email</td>
                                <td>
                                    @if (doctor.IsAvailable)
                                    {
                                        <span class="badge bg-success">Available</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Unavailable</span>
                                    }
                                </td>

                                @if (User.IsInRole("Admin"))
                                {
                                    <td>
                                        <a asp-action="Edit"
                                           asp-route-id="@doctor.DoctorId"
                                           class="btn btn-sm btn-warning">
                                            Edit
                                        </a>

                                        <a asp-action="Delete"
                                           asp-route-id="@doctor.DoctorId"
                                           class="btn btn-sm btn-danger">
                                            Delete
                                        </a>
                                    </td>
                                }
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No doctors found for your search criteria.
                </div>
            }
        </div>
    </div>
</div>