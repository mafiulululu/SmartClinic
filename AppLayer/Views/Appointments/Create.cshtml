@model SmartClinic.Web.ViewModels.AppointmentBookingViewModel

@{
    ViewData["Title"] = "Book Appointment";
}

<div class="container mt-5">
    <h2>Book Appointment</h2>
    <p class="text-muted">Select a doctor and choose your appointment date and time.</p>
    <hr />

    <div class="row">
        <div class="col-md-7">
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="DoctorId" class="form-label"></label>
                    <select asp-for="DoctorId" asp-items="ViewBag.Doctors" class="form-select">
                        <option value="">-- Select Doctor --</option>
                    </select>
                    <span asp-validation-for="DoctorId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="AppointmentDate" class="form-label"></label>
                    <input asp-for="AppointmentDate"
                           type="datetime-local"
                           class="form-control" />
                    <span asp-validation-for="AppointmentDate" class="text-danger"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="SymptomsNotes" class="form-label"></label>
                    <textarea asp-for="SymptomsNotes"
                              class="form-control"
                              rows="4"
                              placeholder="Describe your symptoms or reason for visit"></textarea>
                    <span asp-validation-for="SymptomsNotes" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">
                    Book Appointment
                </button>

                <a asp-controller="PatientDashboard" asp-action="Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}