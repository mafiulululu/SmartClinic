@model IEnumerable<DAL.EF.Table.Appointment>

@{
    ViewData["Title"] = "Doctor Appointments";
}

@functions {
    private string GetStatusBadgeClass(string status)
    {
        return status switch
        {
            "Pending" => "bg-warning text-dark",
            "Approved" => "bg-primary",
            "Cancelled" => "bg-danger",
            "Completed" => "bg-success",
            _ => "bg-secondary"
        };
    }
}

<div class="container mt-4">
    <h2>My Doctor Appointments</h2>
    <p class="text-muted">Appointments booked with you.</p>

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Appointment ID</th>
                            <th>Patient</th>
                            <th>Patient Email</th>
                            <th>Date & Time</th>
                            <th>Status</th>
                            <th>Symptoms / Notes</th>
                            <th style="width: 260px;">Update Status</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.AppointmentId</td>

                                <td>
                                    @item.Patient.FirstName @item.Patient.LastName
                                </td>

                                <td>
                                    @item.Patient.Email
                                </td>

                                <td>
                                    @item.AppointmentDate.ToString("yyyy-MM-dd hh:mm tt")
                                </td>

                                <td>
                                    <span class="badge @GetStatusBadgeClass(item.Status)">
                                        @item.Status
                                    </span>
                                </td>

                                <td>
                                    @item.SymptomsNotes
                                </td>

                                <td>
                                    @if (item.Status != "Completed")
                                    {
                                        <form asp-controller="Appointments"
                                              asp-action="UpdateStatus"
                                              method="post"
                                              class="d-flex gap-2">

                                            @Html.AntiForgeryToken()

                                            <input type="hidden"
                                                   name="appointmentId"
                                                   value="@item.AppointmentId" />

                                            <select name="status" class="form-select form-select-sm">
                                                @if (item.Status == "Pending")
                                                {
                                                    <option value="Pending" selected>Pending</option>
                                                }
                                                else
                                                {
                                                    <option value="Pending">Pending</option>
                                                }

                                                @if (item.Status == "Approved")
                                                {
                                                    <option value="Approved" selected>Approved</option>
                                                }
                                                else
                                                {
                                                    <option value="Approved">Approved</option>
                                                }

                                                @if (item.Status == "Cancelled")
                                                {
                                                    <option value="Cancelled" selected>Cancelled</option>
                                                }
                                                else
                                                {
                                                    <option value="Cancelled">Cancelled</option>
                                                }

                                                @if (item.Status == "Completed")
                                                {
                                                    <option value="Completed" selected>Completed</option>
                                                }
                                                else
                                                {
                                                    <option value="Completed">Completed</option>
                                                }
                                            </select>

                                            <button type="submit" class="btn btn-sm btn-success">
                                                Update
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="text-muted">Locked</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No appointments found for you.
                </div>
            }
        </div>
    </div>
</div>