@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <h2>Admin Dashboard</h2>
    <p>Welcome, @User.Identity?.Name</p>

    <a asp-controller="Doctors" asp-action="Index" class="btn btn-primary">
        Manage Doctors
    </a>
    <a asp-controller="Patients" asp-action="Index" class="btn btn-success ms-2">
        Manage Patients
    </a>
    <a asp-controller="Appointments" asp-action="Index" class="btn btn-info ms-2">
        View Appointments
    </a>
</div>