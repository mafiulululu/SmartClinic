@{
    ViewData["Title"] = "Doctor Dashboard";
}

<div class="container mt-4">
    <h2>Doctor Dashboard</h2>
    <p>Welcome, @User.Identity?.Name</p>

    <div class="mt-3">
        <a asp-controller="Appointments" asp-action="DoctorAppointments" class="btn btn-primary">
            View My Appointments
        </a>

        <a asp-controller="Notifications" asp-action="DoctorNotifications" class="btn btn-warning ms-2">
            My Notifications
        </a>
    </div>
</div>