@model DAL.EF.Table.Patient

@{
    ViewData["Title"] = "Delete Patient";
}

<div class="container mt-5">
    <div class="card border-danger shadow-sm">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0">Delete Patient</h4>
        </div>

        <div class="card-body">
            <div class="alert alert-warning">
                Are you sure you want to delete this patient?
            </div>

            <dl class="row">
                <dt class="col-sm-3">Patient ID</dt>
                <dd class="col-sm-9">@Model.PatientId</dd>

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.FirstName @Model.LastName</dd>

                <dt class="col-sm-3">Email</dt>
                <dd class="col-sm-9">@Model.Email</dd>

                <dt class="col-sm-3">Phone</dt>
                <dd class="col-sm-9">@Model.Phone</dd>

                <dt class="col-sm-3">Date of Birth</dt>
                <dd class="col-sm-9">@Model.Dob.ToString("yyyy-MM-dd")</dd>

                <dt class="col-sm-3">Created At</dt>
                <dd class="col-sm-9">@Model.CreatedAt.ToString("yyyy-MM-dd")</dd>
            </dl>

            <form asp-action="Delete" asp-route-id="@Model.PatientId" method="post">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>

                <a asp-action="Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </form>
        </div>
    </div>
</div>