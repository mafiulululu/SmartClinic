@model IEnumerable<BLL.DTOs.PatientDTO>

@{
    ViewData["Title"] = "Patients";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="mb-0">Patients</h2>
            <p class="text-muted mb-0">Manage clinic patient records</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Add Patient
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm">
        <div class="card-body">
            @if (Model.Any())
            {
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-dark">
                        <tr>
                            <th>Patient ID</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Date of Birth</th>
                            <th>Created At</th>
                            <th style="width: 180px;">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var patient in Model)
                        {
                            <tr>
                                <td>@patient.PatientId</td>
                                <td>@patient.FirstName @patient.LastName</td>
                                <td>@patient.Email</td>
                                <td>@patient.Phone</td>
                                <td>@patient.Dob.ToString("yyyy-MM-dd")</td>
                                <td>@patient.CreatedAt.ToString("yyyy-MM-dd")</td>
                                <td>
                                    <a asp-action="Edit"
                                       asp-route-id="@patient.PatientId"
                                       class="btn btn-sm btn-warning">
                                        Edit
                                    </a>

                                    <a asp-action="Delete"
                                       asp-route-id="@patient.PatientId"
                                       class="btn btn-sm btn-danger">
                                        Delete
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-info mb-0">
                    No patients found. Please add a patient first.
                </div>
            }
        </div>
    </div>
</div>